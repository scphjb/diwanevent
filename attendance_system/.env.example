# ═══════════════════════════════════════
# Diwan Event Platform v3.0 — Configuration Template
# ═══════════════════════════════════════
# انسخ هذا الملف إلى .env وعبّئ القيم

# ─── Security ───────────────────────────
# توليد قيمة آمنة: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32

# مفتاح تشفير منفصل للبيانات الحساسة:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# مفتاح التشفير المتماثل للرسائل الخاصة:
# توليد: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AES_SECRET_KEY=your-generated-fernet-key-here

# مفتاح API للأجهزة المادية (Scanners, Tablets):
# توليد: python -c "import secrets; print(secrets.token_urlsafe(32))"
HARDWARE_API_KEY=your-hardware-api-key-here

# ─── Database ───────────────────────────
DATABASE_URL=postgresql://diwan_user:CHANGE_PASSWORD@localhost:5432/diwan_db

# ─── App Domain ─────────────────────────
APP_DOMAIN=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP) ───────────────────────
EMAILS_FROM_NAME=Diwan Event
EMAILS_FROM_EMAIL=noreply@e-diwan.net
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ─── Chargily Pay (Algeria) ─────────────
CHARGILY_API_KEY=test_xxxxxxxxxxxxxxxx
CHARGILY_API_SECRET=test_xxxxxxxxxxxxxxxx

# ─── Stripe (International) ─────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ─── Performance ────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
